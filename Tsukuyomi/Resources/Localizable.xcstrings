        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tsukuyomi はアプリのライフサイクル、RSS 更新、保存処理、AI リクエスト、基本的なネットワーク状態を記録します。アプリがアクティブになるたびにログキャプチャを更新します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tsukuyomi 会记录应用生命周期、RSS 刷新、持久化、AI 请求和基础网络状态。每次应用进入活跃态时都会刷新日志捕捉器。"
          }
